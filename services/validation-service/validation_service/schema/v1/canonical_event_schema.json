{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "timestamp",
    "tenantId",
    "patientId",
    "source",
    "data"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string"
    },
    "timestamp": {
      "type": "number"
    },
    "tenantId": {
      "type": "string"
    },
    "patientId": {
      "type": "string",
      "format": "uuid"
    },
    "source": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "required": ["resourceType", "id"],
      "properties": {
        "resourceType": {
          "type": "string"
        },
        "id": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}